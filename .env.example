# Ligação ao Postgres da Supabase (Session pooler eu-central-1).
# Copiar para .env.local e preencher. NÃO commitar o .env.local.
PGHOST=aws-1-eu-central-1.pooler.supabase.com
PGPORT=5432
PGUSER=postgres.jszqacdnzhhvbzpxhkvx
PGPASSWORD="a-tua-password"
PGDATABASE=postgres
# Alternativa única (password URL-encoded):
# DATABASE_URL=postgresql://postgres.jszqacdnzhhvbzpxhkvx:PASS@aws-1-eu-central-1.pooler.supabase.com:5432/postgres

# Password de acesso à app (definir no Vercel; sem isto a app fica aberta)
APP_USER=multipark
APP_PASSWORD=

